---@sealed
---@description "Occurs while pressing the Key. Does not occur with a short press."
@Event
script KeyHoldEvent extends EventType

	---@description "Displays the entry event's entry intensity. The keyboard input value is 1.0. Inputs through JoystickComponent can have a value under 1.0."
	---@sealed
	property float inputValue = 1

	---@description "Pressing Key."
	---@sealed
	property KeyboardKey key

	constructor KeyHoldEvent(KeyboardKey key = KeyboardKey.None) end

end